<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_skeleton_shimmer"
    android:padding="16dp">

    <View
        android:id="@+id/skelImage"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="@color/shimmer_highlight"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/skelTitle"
        android:layout_width="200dp"
        android:layout_height="20dp"
        android:layout_marginTop="12dp"
        android:background="@color/shimmer_highlight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skelImage" />

    <View
        android:id="@+id/skelSubtitle"
        android:layout_width="120dp"
        android:layout_height="14dp"
        android:layout_marginTop="8dp"
        android:background="@color/shimmer_highlight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skelTitle" />

    <View
        android:id="@+id/skelButton"
        android:layout_width="0dp"
        android:layout_height="46dp"
        android:layout_marginTop="12dp"
        android:background="@color/shimmer_highlight"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/skelSubtitle" />

</androidx.constraintlayout.widget.ConstraintLayout>
